{
  "name": "erkos-security-dashboard",
  "version": "2.0.0",
  "description": "Enhanced ERKOS Security Dashboard with Functional Analytics",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "deploy": "chmod +x deploy.sh && ./deploy.sh",
    "deploy:production": "pm2 start ecosystem.config.js --env production",
    "deploy:stop": "pm2 stop erkos-security-dashboard",
    "deploy:restart": "pm2 restart erkos-security-dashboard",
    "deploy:logs": "pm2 logs erkos-security-dashboard",
    "deploy:status": "pm2 status",
    "setup:logs": "mkdir -p logs"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mysql2": "^3.6.5",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": ["dashboard", "security", "parking", "analytics", "erkos"],
  "author": "ERKOS Security",
  "license": "MIT"
}
